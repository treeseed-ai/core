---
import BookLayout from '@treeseed/ui/components/astro/layouts/BookLayout.astro';
import PublishedContentBody from '@treeseed/ui/components/astro/site/PublishedContentBody.astro';
import RouteNotFound from '@treeseed/ui/components/astro/site/RouteNotFound.astro';
import { isPublishedRuntimeContentMode, loadPublishedEntry } from '../../utils/site-content-runtime';

export const prerender = false;

const slug = String(Astro.params.slug ?? '');
const publishedRuntime = isPublishedRuntimeContentMode();
const contentApi = publishedRuntime ? null : await import('astro:content');
const books = contentApi ? (await contentApi.getCollection('books')).sort((a, b) => a.data.order - b.data.order) : [];
const localBook = books.find((candidate) => candidate.id === slug || candidate.data.slug === slug) ?? null;
const publishedBook = publishedRuntime ? await loadPublishedEntry(Astro.locals, 'books', slug) : null;
const book = publishedRuntime ? publishedBook?.entry ?? null : localBook;
if (!book) {
	Astro.response.status = 404;
}
const rendered = contentApi && localBook ? await contentApi.render(localBook) : null;
const Content = rendered?.Content ?? null;
---

{
	!book || (!Content && !publishedBook?.html) ? (
		<RouteNotFound title="Book not found" description="The requested book could not be found in this Treeseed." currentPath="/books/" />
	) : (
		<BookLayout entry={book.data} currentPath="/books/">
			{publishedBook?.html ? <PublishedContentBody html={publishedBook.html} /> : Content ? <Content /> : null}
		</BookLayout>
	)
}
