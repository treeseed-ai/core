---
import CoreStyleScope from '../../layouts/CoreStyleScope.astro';
import MainLayout from '@treeseed/ui/components/astro/layouts/MainLayout.astro';
import SectionIntro from '@treeseed/ui/components/astro/site/SectionIntro.astro';
import BookList from '@treeseed/ui/components/astro/site/BookList.astro';
import { isPublishedRuntimeContentMode, loadPublishedCollection } from '../../utils/site-content-runtime';

const publishedRuntime = isPublishedRuntimeContentMode();
const books = publishedRuntime
	? (await loadPublishedCollection(Astro.locals, 'books')).sort((a, b) => Number(a.data.order ?? 0) - Number(b.data.order ?? 0))
	: (await (await import('astro:content')).getCollection('books')).sort((a, b) => a.data.order - b.data.order);
---

<CoreStyleScope>

<MainLayout title="Books" description="Queryable book metadata for the TreeSeed working site." currentPath="/books/">
	<div class="space-y-10">
		<SectionIntro
			eyebrow="Books"
			title="Books as first-class treeseed records"
			description="Books hold the longer-form accumulated knowledge of the platform. This index exposes them as queryable metadata entries instead of burying them inside navigation code."
		/>
		<BookList
			items={books.map((book) => ({
				href: `/books/${book.id}/`,
				title: book.data.title,
				summary: book.data.summary,
				meta: book.data.sectionLabel,
				landingPath: book.data.landingPath,
				downloadHref: book.data.downloadHref,
			}))}
		/>
	</div>
</MainLayout>
</CoreStyleScope>
