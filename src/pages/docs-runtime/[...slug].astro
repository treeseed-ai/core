---
import MainLayout from '@treeseed/ui/components/astro/layouts/MainLayout.astro';
import PublishedContentBody from '@treeseed/ui/components/astro/site/PublishedContentBody.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import ReaderTemplate from '@treeseed/ui/components/astro/templates/ReaderTemplate.astro';
import { isPublishedRuntimeContentMode } from '../../utils/site-content-runtime';
import { buildPublicKnowledgeReaderViewModel } from '../../utils/runtime-reader';

export const prerender = false;

const slug = String(Astro.params.slug ?? '').replace(/^\/+|\/+$/gu, '');
const publishedRuntime = isPublishedRuntimeContentMode();
const contentApi = publishedRuntime ? null : await import('astro:content');
const localEntries = contentApi ? await contentApi.getCollection('docs').catch(() => []) : [];
const viewModel = await buildPublicKnowledgeReaderViewModel({
	locals: Astro.locals,
	slug,
	localDocuments: localEntries.map((entry: any) => ({
		id: entry.id,
		slug: entry.slug,
		data: entry.data,
	})),
});
const localEntry = contentApi && viewModel.localDocumentId
	? localEntries.find((entry: any) => entry.id === viewModel.localDocumentId) ?? null
	: null;
const rendered = contentApi && localEntry ? await contentApi.render(localEntry) : null;
const Content = rendered?.Content ?? null;
if (viewModel.status === 'not_found') Astro.response.status = 404;
if (viewModel.status === 'unavailable') Astro.response.status = 503;
for (const [name, value] of Object.entries(viewModel.cache.headers)) {
	Astro.response.headers.set(name, value);
}
---

<MainLayout title={viewModel.title} description={viewModel.description} currentPath={viewModel.currentPath} helpContext={viewModel.help} feedbackContext={viewModel.feedback}>
	<ReaderTemplate
		title={viewModel.title}
		description={viewModel.description}
		actions={viewModel.actions}
		navGroups={viewModel.navGroups}
	>
		{viewModel.status === 'ready' ? (
			viewModel.publishedHtml ? (
				<PublishedContentBody html={viewModel.publishedHtml} />
			) : Content ? (
				<Content />
			) : (
				<EmptyState title="Knowledge page unavailable" description="This local knowledge page could not be rendered." />
			)
		) : (
			<EmptyState
				eyebrow={viewModel.source === 'r2_published_manifest' ? 'Published runtime' : 'Knowledge'}
				title={viewModel.errorTitle ?? viewModel.title}
				description={viewModel.errorDescription ?? viewModel.description}
				actions={[{ label: 'Open books', href: '/books/' }]}
			/>
		)}
	</ReaderTemplate>
</MainLayout>
