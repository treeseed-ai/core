---
import MainLayout from '@treeseed/ui/components/astro/layouts/MainLayout.astro';
import SectionIntro from '@treeseed/ui/components/astro/site/SectionIntro.astro';
import ProfileList from '@treeseed/ui/components/astro/site/ProfileList.astro';
import { isPublishedRuntimeContentMode, loadPublishedCollection } from '../../utils/site-content-runtime';

const publishedRuntime = isPublishedRuntimeContentMode();
const people = publishedRuntime
	? await loadPublishedCollection(Astro.locals, 'people')
	: await (await import('astro:content')).getCollection('people');
---

<MainLayout title="People" description="Human contributors participating in the TreeSeed working site." currentPath="/people/">
	<div class="space-y-10">
		<SectionIntro
			eyebrow="People"
			title="Human contributors in the Treeseed"
			description="People entries make human stewardship explicit. They show who is participating in the hub, what posture they hold, and which questions and objectives they are linked to."
		/>
		<ProfileList
			items={people.map((person) => ({
				href: `/people/${person.id}/`,
				name: person.data.name,
				summary: person.data.summary,
				meta: `${person.data.role} · ${person.data.affiliation}`,
				status: person.data.status,
				tags: person.data.tags,
			}))}
		/>
	</div>
</MainLayout>
