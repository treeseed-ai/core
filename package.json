{
  "name": "@treeseed/core",
  "version": "0.10.23-dev.staging.20260610T233716Z",
  "description": "Treeseed web framework package for Astro/Starlight site runtimes.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/treeseed-ai/core.git",
    "directory": "."
  },
  "homepage": "https://treeseed.ai",
  "bugs": {
    "url": "https://github.com/treeseed-ai/core/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "scripts/verify-driver.mjs",
    "tsconfigs",
    "templates",
    "style",
    "utils"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "treeseed-workspace-bootstrap": "./dist/scripts/workspace-bootstrap.js"
  },
  "scripts": {
    "setup": "npm install",
    "setup:ci": "npm ci",
    "build:dist": "node ./scripts/run-ts.mjs ./scripts/build-dist.ts",
    "prepare": "node ./scripts/prepare.mjs",
    "prepack": "npm run build:dist",
    "dev": "node ./scripts/run-ts.mjs ./scripts/dev-platform.ts",
    "dev:web": "node ./scripts/run-ts.mjs ./scripts/dev-platform.ts --surface web",
    "dev:watch": "node ./scripts/run-ts.mjs ./scripts/dev-platform.ts --watch",
    "starlight:patch": "node ./scripts/run-ts.mjs ./scripts/patch-starlight-content-path.ts",
    "precheck": "npm run starlight:patch",
    "check": "node ./scripts/run-ts.mjs ./scripts/run-fixture-astro-command.ts check",
    "prebuild": "npm run starlight:patch && node ./scripts/run-ts.mjs ./scripts/aggregate-book.ts",
    "build": "TREESEED_LOCAL_DEV_MODE=cloudflare node ./scripts/run-ts.mjs ./scripts/run-fixture-astro-command.ts build",
    "preview": "node ./scripts/run-ts.mjs ./scripts/run-fixture-astro-command.ts preview",
    "test:unit": "vitest run --config ./vitest.config.ts",
    "test": "npm run test:unit",
    "lint": "npm run fixtures:check && npm run starlight:patch && npm run build:dist",
    "verify:direct": "npm run release:verify",
    "verify:local": "node --input-type=module -e \"process.env.TREESEED_VERIFY_DRIVER='direct'; await import('./scripts/verify-driver.mjs')\"",
    "verify:action": "node --input-type=module -e \"process.env.TREESEED_VERIFY_DRIVER='act'; await import('./scripts/verify-driver.mjs')\"",
    "verify": "node --input-type=module -e \"await import('./scripts/verify-driver.mjs')\"",
    "test:smoke": "node ./scripts/run-ts.mjs ./scripts/test-smoke.ts",
    "fixtures:resolve": "node ./scripts/run-ts.mjs ./scripts/fixture-tools.ts resolve",
    "fixtures:check": "node ./scripts/run-ts.mjs ./scripts/fixture-tools.ts check",
    "release:setup": "npm run setup:ci",
    "release:check-tag": "node ./scripts/run-ts.mjs ./scripts/assert-release-tag-version.ts",
    "release:verify": "node ./scripts/run-ts.mjs ./scripts/release-verify.ts",
    "release:publish": "node ./scripts/run-ts.mjs ./scripts/publish-package.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/markdown-remark": "^6.3.11",
    "@astrojs/mdx": "^4.3.14",
    "@astrojs/sitemap": "3.7.0",
    "@astrojs/starlight": "0.37.6",
    "@tailwindcss/vite": "^4.1.4",
    "@treeseed/sdk": "github:treeseed-ai/sdk#0.10.29-dev.staging.20260610T232358Z",
    "@treeseed/ui": "github:treeseed-ai/ui#0.1.9-dev.staging.20260610T232358Z",
    "astro": "^5.6.1",
    "esbuild": "^0.28.0",
    "katex": "^0.16.22",
    "nodemailer": "^8.0.4",
    "rehype-katex": "^7.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwindcss": "^4.1.4",
    "typescript": "^5.9.3",
    "unified": "^11.0.5",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^7.0.11"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./site": {
      "types": "./dist/site.d.ts",
      "default": "./dist/site.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./platform": {
      "types": "./dist/platform.d.ts",
      "default": "./dist/platform.js"
    },
    "./dev": {
      "types": "./dist/dev.d.ts",
      "default": "./dist/dev.js"
    },
    "./plugin-default": {
      "types": "./dist/plugin-default.d.ts",
      "default": "./dist/plugin-default.js"
    },
    "./content": {
      "types": "./dist/content.d.ts",
      "default": "./dist/content.js"
    },
    "./content-config": {
      "types": "./dist/content-config.d.ts",
      "default": "./dist/content-config.js"
    },
    "./templates": {
      "types": "./dist/templates.d.ts",
      "default": "./dist/templates.js"
    },
    "./middleware/editorial-preview": {
      "types": "./dist/middleware/editorial-preview.d.ts",
      "default": "./dist/middleware/editorial-preview.js"
    },
    "./tenant": "./dist/tenant/bridge.js",
    "./scripts/dev-platform": "./dist/scripts/dev-platform.js",
    "./scripts/workspace-bootstrap": "./dist/scripts/workspace-bootstrap.js",
    "./launch": {
      "types": "./dist/launch.d.ts",
      "default": "./dist/launch.js"
    },
    "./site-resources": {
      "types": "./dist/site-resources.d.ts",
      "default": "./dist/site-resources.js"
    },
    "./types/cloudflare": {
      "types": "./dist/types/cloudflare.d.ts",
      "default": "./dist/types/cloudflare.js"
    },
    "./utils/seo": "./dist/utils/seo.js",
    "./utils/site-config-schema": "./dist/utils/site-config-schema.js",
    "./utils/forms/service": {
      "types": "./dist/utils/forms/service.d.ts",
      "default": "./dist/utils/forms/service.js"
    },
    "./tsconfigs/strict": "./dist/tsconfigs/strict.json"
  }
}
